#!/usr/bin/env bash
# Exactly what CI runs (.github/workflows/ci.yml) — green here means green there.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "── cargo fmt --check"
cargo fmt --check
echo "── cargo clippy"
cargo clippy --all-targets --locked -- -D warnings
echo "── cargo test"
cargo test --locked
echo "check: all green"
